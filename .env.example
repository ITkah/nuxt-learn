# Copy to .env for local dev outside Docker (optional when using docker compose up -d).

# ── Backend devs (run the DB + Nitro locally) ───────────────────────
# Local npm run dev (DB in Docker, app on host):
DATABASE_URL="postgresql://nuxt:nuxt@localhost:5533/nuxt_learn?schema=public"
#
# npm start runs everything in Docker — compose overrides DATABASE_URL to use host "db".

# JWT secret (HS256). Generate your own — DON'T reuse this placeholder.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET="replace-me"

# ── Frontend-only devs (use a shared backend) ───────────────────────
# Set this to the shared backend URL to proxy /api there (same-origin,
# cookies work). Leave empty to use the local backend above.
# Example: API_PROXY_TARGET="https://abc-123.trycloudflare.com"
API_PROXY_TARGET=""
